# Password Manager Environment Variables
# Copy this file to .env.local and fill in your values

# Master Password Hash (generate using: echo -n "your-password" | sha256sum)
NEXT_PUBLIC_MASTER_PASSWORD_HASH=your_password_hash_here

# Encryption Secret Key (min 32 characters)
ENCRYPTION_SECRET_KEY=your_super_secret_encryption_key_here_min_32_chars

# Database URL (optional - for future database integration)
DATABASE_URL=

# Node Environment
NODE_ENV=development

# Vercel Deployment
VERCEL_ENV=development
